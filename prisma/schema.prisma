generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ──────────────────────────────────────────────────────────────

model Usuario {
  id                String    @id @default(cuid())
  nombre            String
  email             String    @unique
  password          String
  telefono          String?
  ciudad            String?   @default("santiago")
  fotoUrl           String    @default("")
  tipo              String    @default("usuario")
  emailVerificado   Boolean   @default(false)
  emailVerificadoAt DateTime?
  tokenVerificacion String?
  resetToken        String?
  resetTokenExpira  DateTime?
  estiloAlimentario String    @default("")
  comidasFavoritas  String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─── Restaurants ────────────────────────────────────────────────────────

model Local {
  id          String   @id @default(cuid())
  slug        String?  @unique
  nombre      String
  email       String   @unique
  password    String
  telefono    String?
  ciudad      String   @default("santiago")
  categorias  String[] @default([])
  descripcion String?
  direccion   String?
  comuna      String?
  lat         Float?
  lng         Float?
  instagram   String?
  sitioWeb    String?
  horarios    Json?
  logoUrl     String?
  portadaUrl  String?
  activo      Boolean  @default(true)
  vistas      Int      @default(0)
  linkPedido  String?  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems MenuItem[]

  @@index([activo])
  @@index([comuna])
}

// ─── Menu Items ─────────────────────────────────────────────────────────

model MenuItem {
  id          String   @id @default(cuid())
  localId     String
  categoria   String
  nombre      String
  descripcion String?
  precio      Float
  imagenUrl   String?
  destacado   Boolean  @default(false)
  createdAt   DateTime @default(now())

  ingredients    String[]
  ingredientTags IngredientTag[]
  dietType       DietType        @default(OMNIVORE)
  mealTimes      String[]        @default([])
  hungerLevel    HungerLevel?
  isAvailable    Boolean         @default(true)
  availableFrom  String?
  availableTo    String?
  totalViews     Int             @default(0)
  totalSelected  Int             @default(0)
  totalLoved     Int             @default(0)
  avgRating      Float?

  local        Local         @relation(fields: [localId], references: [id])
  interactions Interaction[]
  ratings      DishRating[]
}

enum HungerLevel {
  LIGHT
  MEDIUM
  HEAVY
}

enum DietType {
  VEGAN
  VEGETARIAN
  OMNIVORE
}

// ─── Ingredients ────────────────────────────────────────────────────────

model Ingredient {
  id              String             @id @default(cuid())
  name            String             @unique
  nameEn          String?
  namePt          String?
  aliases         String[]
  category        IngredientCategory
  createdAt       DateTime           @default(now())
  dishes          IngredientTag[]
  dishIngredients DishIngredient[]
  allergens       Allergen[]         // many-to-many: qué alérgenos tiene este ingrediente
}

model Allergen {
  id          String       @id @default(cuid())
  name        String       @unique  // "gluten", "lactosa", "cerdo", "alcohol", etc
  type        AllergenType @default(ALLERGEN)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  ingredients Ingredient[] // many-to-many: ingredientes vinculados
}

enum AllergenType {
  ALLERGEN     // alérgenos reales (gluten, lactosa, maní, etc)
  RESTRICTION  // preferencias dietarias (cerdo, alcohol, etc)
}

model IgnoredIngredient {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

enum IngredientCategory {
  PROTEIN
  VEGETABLE
  FRUIT
  DAIRY
  CARB
  SAUCE
  SPICE
  OTHER
}

model IngredientTag {
  id           String @id @default(cuid())
  menuItemId   String
  ingredientId String

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([menuItemId, ingredientId])
}

// ─── Interactions ───────────────────────────────────────────────────────

model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String?
  sessionId  String
  visitId    String?
  menuItemId String

  action      InteractionAction
  ctxCompany  CompanyContext?
  ctxHunger   HungerLevel?
  ctxBudget   Int?
  ctxOccasion OccasionContext?

  weatherTemp      Float?
  weatherCondition String?
  weatherHumidity  Int?
  userLat          Float?
  userLng          Float?

  hour      Int?
  dayOfWeek Int?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([visitId])
  @@index([menuItemId])
}

enum InteractionAction {
  VIEWED
  SELECTED
  IGNORED
  LOVED
  MEH
  DISLIKED
}

enum CompanyContext {
  SOLO
  PAREJA
  AMIGOS
  FAMILIA
}

enum OccasionContext {
  ALMUERZO_RAPIDO
  CENA_TRANQUILA
  ALGO_ESPECIAL
  TRABAJAR_AQUI
  CUMPLEANOS
  CITA_ROMANTICA
  JUNTA_AMIGOS
  CON_NINOS
  FAMILIAR
}

// ─── Ratings ────────────────────────────────────────────────────────────

model DishRating {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String?
  sessionId  String
  menuItemId String

  score    RatingScore
  stars    Int?
  comment  String?
  userName String?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([userId, menuItemId])
  @@index([menuItemId])
}

enum RatingScore {
  LOVED
  MEH
  DISLIKED
}

// ─── User Taste Profile ─────────────────────────────────────────────────

model UserTasteProfile {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  userId    String  @unique
  sessionId String?

  favoriteIngredients String[]
  avoidIngredients    String[]

  typicalHunger  HungerLevel?
  typicalCompany CompanyContext?
  typicalBudget  Int?

  coldWeatherPrefs String[]
  hotWeatherPrefs  String[]

  onboardingDone      Boolean     @default(false)
  dietaryRestrictions String[]
  riskProfile         RiskProfile @default(BALANCED)

  fitnessMode      FitnessMode?
  fitnessUpdatedAt DateTime?
}

enum FitnessMode {
  GAINING
  CUTTING
  MAINTAINING
  NONE
}

enum RiskProfile {
  SAFE
  BALANCED
  EXPLORER
}

// ─── Group Sessions ─────────────────────────────────────────────────────

model GroupSession {
  id             String        @id @default(cuid())
  code           String        @unique
  createdAt      DateTime      @default(now())
  expiresAt      DateTime
  creatorId      String?
  creatorSession String?
  groupType      GroupType
  totalMembers   Int
  estado         GroupStatus   @default(WAITING)
  resultLocalId  String?
  members        GroupMember[]

  @@index([code])
}

model GroupMember {
  id                String       @id @default(cuid())
  groupId           String
  userId            String?
  sessionId         String
  nombre            String       @default("Invitado")
  estado            MemberStatus @default(WAITING)
  selectedDishes    String[]
  ctxHunger         String?
  ctxBudget         Int?
  recommendedDishId String?
  joinedAt          DateTime     @default(now())
  readyAt           DateTime?

  group GroupSession @relation(fields: [groupId], references: [id])

  @@unique([groupId, sessionId])
  @@index([groupId])
}

enum GroupType {
  PAREJA
  AMIGOS
  FAMILIA
}

enum GroupStatus {
  WAITING
  SELECTING
  CALCULATING
  READY
  EXPIRED
}

enum MemberStatus {
  WAITING
  SELECTING
  READY
  RECALCULATING
}

// ═══════════════════════════════════════════════════════════════════════════
// ─── Carta QR Viva (qr.quierocomer.cl) ────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════

model RestaurantOwner {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  role         OwnerRole   @default(OWNER)
  status       OwnerStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  mustChangePassword Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurants Restaurant[]
  uploadedTickets RestaurantTicket[]

  @@index([resetToken])
}

enum OwnerRole {
  OWNER
  SUPERADMIN
}

enum OwnerStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model Restaurant {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  logoUrl     String?
  bannerUrl   String?
  phone       String?
  address     String?
  instagram   String?
  website     String?
  whatsapp    String?     // formato +56 9 1234 5678
  scheduleJson Json?      // { "lun": "12:00-23:00", ..., "dom": "closed" }
  cartaTheme  CartaTheme @default(BASIC)
  defaultView        String?    // "premium" | "lista" | "viaje" — vista por defecto para nuevos visitantes
  waiterPanelActive  Boolean    @default(false)
  qrActivatedAt      DateTime?  // fecha en que se activó la carta QR para este restaurante
  qrToken            String?    @unique  // token único embebido en el QR impreso, para futuras features sin reimprimir
  isActive           Boolean    @default(true)
  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       RestaurantOwner? @relation(fields: [ownerId], references: [id])
  sessions    Session[]
  categories  Category[]
  dishes      Dish[]
  tables      RestaurantTable[]
  waiterCalls WaiterCall[]
  customers   Customer[]
  reviews     Review[]
  statEvents  StatEvent[]
  promotions  RestaurantPromotion[]
  birthdays   BirthdayCampaign[]
  schedules             RestaurantScheduleRule[]
  waiterSubscriptions   WaiterPushSubscription[]
  qrUserInteractions    QRUserInteraction[]
  segments              Segment[]
  campaigns             Campaign[]
  promotionsMarketing   Promotion[]
  automationRules       AutomationRule[]
  genioInsights         GenioInsight[]
  modifierTemplates     ModifierTemplate[]
  experience            Experience?
  tickets               RestaurantTicket[]
  dishFavorites         DishFavorite[]
  happyHours            HappyHour[]

  @@index([ownerId])
}

enum CartaTheme {
  BASIC
  PREMIUM
}

model Category {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  position     Int
  isActive     Boolean  @default(true)
  dishType     String   @default("food") // "food" | "drink" | "dessert"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant            @relation(fields: [restaurantId], references: [id])
  dishes       Dish[]
  translations CategoryTranslation[]

  @@index([restaurantId])
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  lang       String   // "en" | "pt"
  name       String
  isManual   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@index([categoryId])
}

model Dish {
  id             String       @id @default(cuid())
  restaurantId   String
  categoryId     String
  name           String
  description    String?
  price          Float
  discountPrice  Float?
  photos         String[]
  tags           DishTag[]
  isHero         Boolean      @default(false)
  isActive       Boolean      @default(true)
  deletedAt      DateTime?    // soft delete — null = activo, fecha = eliminado
  stockCountdown Int?
  ingredients    String?      // legacy text field (kept for backwards compat)
  allergens      String?      // legacy text field
  dishDiet       DishDietType @default(OMNIVORE)
  isSpicy        Boolean      @default(false)
  isHighMargin   Boolean      @default(false)
  isFeaturedAuto Boolean      @default(false)
  flavorTags     String[]     // "dulce","agridulce","umami","ácido","ahumado","picante"
  position       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  restaurant          Restaurant            @relation(fields: [restaurantId], references: [id])
  category            Category              @relation(fields: [categoryId], references: [id])
  reviews             Review[]
  dishIngredients     DishIngredient[]
  dishFavorites       DishFavorite[]
  modifierTemplates   ModifierTemplate[]     // many-to-many: plantillas de modificadores asignadas
  translations        DishTranslation[]

  @@index([restaurantId])
  @@index([categoryId])
}

model DishTranslation {
  id          String   @id @default(cuid())
  dishId      String
  lang        String   // "en" | "pt"
  description String?
  isManual    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([dishId, lang])
  @@index([dishId])
}

model ModifierTemplate {
  id           String   @id @default(cuid())
  restaurantId String
  name         String                        // "Envolturas", "Salsas", "Tamaño"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant              @relation(fields: [restaurantId], references: [id])
  groups     ModifierTemplateGroup[]
  dishes     Dish[]                          // many-to-many: platos que usan esta plantilla

  @@index([restaurantId])
}

model ModifierTemplateGroup {
  id         String   @id @default(cuid())
  templateId String
  name       String                         // "Elige tu Roll", "Envoltura"
  required   Boolean  @default(false)
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  position   Int      @default(0)

  template ModifierTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  options  ModifierTemplateOption[]

  @@index([templateId])
}

model ModifierTemplateOption {
  id              String  @id @default(cuid())
  groupId         String
  name            String                      // "Salmón Roll", "Papel soya"
  description     String?                     // descripción opcional que reemplaza la del plato
  imageUrl        String?                     // foto opcional que reemplaza la del plato
  priceAdjustment Float   @default(0)
  isDefault       Boolean @default(false)
  isHidden        Boolean @default(false)
  position        Int     @default(0)

  group ModifierTemplateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

enum DishDietType {
  VEGAN
  VEGETARIAN
  OMNIVORE
}

model DishIngredient {
  id           String @id @default(cuid())
  dishId       String
  ingredientId String

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([dishId, ingredientId])
  @@index([dishId])
  @@index([ingredientId])
}

enum DishTag {
  RECOMMENDED
  NEW
  MOST_ORDERED
  PROMOTION
}

model RestaurantTable {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  tableNumber  Int
  qrCode       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id])
  waiterCalls WaiterCall[]

  @@index([restaurantId])
}

model WaiterCall {
  id           String    @id @default(cuid())
  tableId      String?
  tableName    String?
  restaurantId String
  sessionId    String?
  guestId      String?
  dietType     String?
  restrictions String?
  dislikes     String?
  calledAt     DateTime
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())

  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([tableId])
  @@index([sessionId])
  @@index([calledAt])
}

model Customer {
  id           String    @id @default(cuid())
  restaurantId String
  email        String?
  name         String?
  birthDate    DateTime?
  preferences  Json?
  cookieId     String?
  isSubscribed Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  reviews    Review[]

  @@index([restaurantId])
}

model Review {
  id           String   @id @default(cuid())
  restaurantId String
  customerId   String
  dishId       String
  rating       Int
  isVerified   Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])
  dish       Dish       @relation(fields: [dishId], references: [id])

  @@index([restaurantId])
  @@index([dishId])
}

model StatEvent {
  id           String        @id @default(cuid())
  restaurantId String
  dishId       String?
  categoryId   String?
  tableId      String?
  promoId      String?
  eventType    StatEventType
  sessionId    String        // UUID de tab (legacy)
  dbSessionId  String?       // Session.id real de la DB
  guestId      String?
  qrUserId     String?
  weather         String?
  timeOfDay       TimeOfDay?
  query           String?        // para SEARCH_PERFORMED
  resultsCount    Int?           // para SEARCH_PERFORMED y FILTER_APPLIED
  clickedResultId String?        // para SEARCH_PERFORMED
  genioSessionId  String?        // UUID compartido entre eventos de una misma interacción del Genio
  metadata        Json?          // genérico: filterType, filterValue, triggered_by, etc.
  createdAt       DateTime       @default(now())

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  guest        GuestProfile? @relation(fields: [guestId], references: [id])
  qrUser       QRUser?       @relation(fields: [qrUserId], references: [id])

  @@index([restaurantId])
  @@index([guestId])
  @@index([qrUserId])
  @@index([sessionId])
  @@index([dbSessionId])
  @@index([genioSessionId])
  @@index([eventType, createdAt])
}

enum StatEventType {
  DISH_VIEW
  DISH_SELECT
  DISH_DWELL
  CATEGORY_VIEW
  CATEGORY_DWELL
  SESSION_START
  SESSION_END
  GENIO_START
  GENIO_COMPLETE
  GENIO_DISH_ACCEPTED
  GENIO_DISH_REJECTED
  GENIO_GROUP_START
  GENIO_STEP_DIET
  GENIO_STEP_RESTRICTIONS
  GENIO_STEP_DISLIKES
  GENIO_STEP_GRID
  GENIO_STEP_RESULTS
  GENIO_FEEDBACK_LIKE
  GENIO_FEEDBACK_DISLIKE
  CARTA_VIEW_SELECTED
  PROMO_VIEWED
  PROMO_CLICKED
  PROMO_REDEEMED
  PROMO_DISH_VIEWED
  WAITER_CALL
  QR_SCAN
  SEARCH_PERFORMED
  FILTER_APPLIED
  USER_REGISTERED
  DISH_FAVORITED
  DISH_UNFAVORITED
  RECOMMENDATION_SHOWN
  RECOMMENDATION_TAPPED
  BIRTHDAY_BANNER_CLICKED
  BIRTHDAY_SAVED
  GENIO_PROFILE_SAVED
}

enum TimeOfDay {
  MORNING
  LUNCH
  AFTERNOON
  DINNER
  LATE
}

model RestaurantPromotion {
  id           String        @id @default(cuid())
  restaurantId String
  type         PromotionType
  message      String?
  dishId       String?
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

enum PromotionType {
  BANNER
  COUNTDOWN
  HIGHLIGHT
}

model BirthdayCampaign {
  id               String   @id @default(cuid())
  restaurantId     String
  promoDescription String
  emailSubject     String
  emailBody        String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model RestaurantScheduleRule {
  id           String           @id @default(cuid())
  restaurantId String
  ruleType     ScheduleRuleType
  condition    String
  categoryId   String?
  dishId       String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

enum ScheduleRuleType {
  TIME_OF_DAY
  WEATHER
}

// ─── Happy Hour / Horarios especiales ────────────────────────────────

model HappyHour {
  id             String   @id @default(cuid())
  restaurantId   String
  name           String                    // "Hand Roll Hour"
  days           Int[]                     // 0=dom, 1=lun, ... 6=sab
  startTime      String                    // "16:00"
  endTime        String                    // "19:00"
  discountType   HappyHourDiscountType     // FIXED_PRICE or PERCENTAGE
  discountValue  Float                     // 3990 (fixed) or 20 (percent)
  categoryIds    String[]                  // categories affected
  dishIds        String[]                  // specific dishes (if empty = all in categories)
  bannerText     String?                   // "Todos los hand rolls a $3.990"
  bannerColor    String   @default("#f59e0b") // gradient accent color
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

enum HappyHourDiscountType {
  FIXED_PRICE
  PERCENTAGE
}

model WaiterPushSubscription {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  endpoint     String     @unique
  p256dh       String
  auth         String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

// ─── Guest Profile (anonymous visitors) ──────────────────────────────

model GuestProfile {
  id              String    @id // = quierocomer_guest_id from localStorage
  createdAt       DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  visitCount      Int       @default(1)
  totalSessions   Int       @default(0)
  preferences          Json?     // { dietType, restrictions[], dislikes[], favoriteCategories[] }
  favoriteIngredients  Json?     // { "salmón": 12, "palta": 8, ... } — acumulativo por score
  linkedQrUserId       String?
  linkedQrUser    QRUser?   @relation(fields: [linkedQrUserId], references: [id])
  convertedToUserAt    DateTime?
  deviceType           String?

  statEvents      StatEvent[]
  sessions        Session[]
  dishFavorites   DishFavorite[]

  @@index([linkedQrUserId])
}

// ─── Session ─────────────────────────────────────────────────────────

model Session {
  id             String    @id @default(cuid())
  guestId        String
  qrUserId       String?
  restaurantId   String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  durationMs     Int?
  viewUsed       String?   // última vista activa
  viewHistory    Json?     // [{ view: 'premium', durationMs: 12000 }, ...]
  deviceType     String?   // 'mobile' | 'tablet' | 'desktop'
  ipAddress      String?
  userAgent      String?
  referer        String?
  externalReferer String?
  language       String?
  closeReason    String?   // 'inactivity' | 'pagehide' | 'beforeunload'
  weather        String?
  timeOfDay      TimeOfDay?
  dishesViewed   Json?     // [{ dishId, dwellMs }]
  categoriesViewed Json?   // [{ categoryId, dwellMs }]
  pickedDishId   String?
  isBot          Boolean   @default(false)
  isAbandoned    Boolean   @default(false)
  searchesCount       Int     @default(0)
  converted           Boolean @default(false)
  isReturningVisitor  Boolean @default(false)
  isQrScan            Boolean @default(false)
  tableId             String?

  guest          GuestProfile @relation(fields: [guestId], references: [id])
  qrUser         QRUser?      @relation(fields: [qrUserId], references: [id])
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  tickets        RestaurantTicket[]
  dishImpressions DishImpression[]

  @@index([guestId])
  @@index([qrUserId])
  @@index([restaurantId])
  @@index([startedAt])
}

// ─── QR User Capture ──────────────────────────────────────────────────

model QRUser {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  birthDate    DateTime?
  dietType     String?
  restrictions String[]
  dislikes     String[]
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  unsubscribedAt   DateTime?
  lastEmailAt      DateTime?
  triggerHistory   Json?     // { birthday: "2026-04-18", inactivity: "2026-04-10", ... }

  magicTokens  QRMagicToken[]
  interactions QRUserInteraction[]
  guestProfiles GuestProfile[]
  sessions     Session[]
  statEvents   StatEvent[]
  campaignRecipients CampaignRecipient[]
  dishFavorites DishFavorite[]
}

model QRMagicToken {
  id        String    @id @default(cuid())
  userId    String
  user      QRUser    @relation(fields: [userId], references: [id])
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model BannerVariant {
  id          String   @id @default(cuid())
  text        String
  impressions Int      @default(0)
  conversions Int      @default(0)
  isWinner    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QRUserInteraction {
  id              String      @id @default(cuid())
  userId          String?
  user            QRUser?     @relation(fields: [userId], references: [id])
  restaurantId    String
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  type            String
  bannerVariantId String?
  sessionId       String?
  createdAt       DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@index([createdAt])
}

model Referrer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String   @unique
  code      String   @unique @default(cuid())
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Cron ─────────────────────────────────────────────────────────────

model CronLog {
  id          String   @id @default(cuid())
  jobName     String
  status      String   // 'success' | 'error'
  durationMs  Int
  details     Json?    // { sessionsAbandoned, guestsUpdated, etc }
  error       String?
  createdAt   DateTime @default(now())

  @@index([jobName])
  @@index([createdAt])
}

// ─── Email Log ───────────────────────────────────────────────────────

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  purpose   String   // password_reset, welcome, campaign, automation, experience
  status    String   // sent, failed
  errorMsg  String?
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
}

// ─── Marketing ────────────────────────────────────────────────────────

model Segment {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  description   String?
  rules         Json     // [{ field, operator, value }]
  isAuto        Boolean  @default(false)
  cachedCount   Int?
  cachedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  campaigns     Campaign[]

  @@index([restaurantId])
}

model Campaign {
  id            String         @id @default(cuid())
  restaurantId  String
  segmentId     String?
  name          String
  status        CampaignStatus @default(DRAFT)
  subject       String?
  bodyHtml      String?
  scheduledFor  DateTime?
  sentAt        DateTime?
  stats         Json?          // { sent, opened, clicked, bounced }
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  restaurant    Restaurant          @relation(fields: [restaurantId], references: [id])
  segment       Segment?            @relation(fields: [segmentId], references: [id])
  recipients    CampaignRecipient[]

  @@index([restaurantId])
  @@index([status])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model CampaignRecipient {
  id          String    @id @default(cuid())
  campaignId  String
  qrUserId    String
  status      String    @default("queued") // queued, sent, failed, bounced
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  createdAt   DateTime  @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  qrUser      QRUser   @relation(fields: [qrUserId], references: [id])

  @@index([campaignId])
  @@index([qrUserId])
}

model Promotion {
  id              String          @id @default(cuid())
  restaurantId    String
  name            String
  description     String?
  promoType       String          @default("product") // "product" | "graphic"
  imageUrl        String?         // for graphic type: custom design image (optimized)
  thumbUrl        String?         // thumbnail 300px for carousel card
  dishIds         String[]
  originalPrice   Float?
  promoPrice      Float?
  discountPct     Int?
  validFrom       DateTime?
  validUntil      DateTime?
  daysOfWeek      Int[]           @default([]) // 0=dom,1=lun,...6=sab. Vacío=todos los días
  status          PromotionStatus @default(SUGGESTED)
  generatedBy     String          @default("manual") // ai, manual
  aiJustification String?
  metrics         Json?           // { views, clicks, redemptions }
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([status])
}

enum PromotionStatus {
  SUGGESTED
  ACTIVE
  PAUSED
  DELETED
}

model AutomationRule {
  id            String   @id @default(cuid())
  restaurantId  String
  name          String
  trigger       String   // birthday, inactivity, welcome, milestone
  triggerConfig Json?    // { daysInactive: 30, milestoneVisit: 5, etc }
  subject       String?
  bodyHtml      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model GenioInsight {
  id            String   @id @default(cuid())
  restaurantId  String?
  type          String   // menu_gap, segment_opportunity, pricing, engagement, platform, comparison, opportunity
  title         String
  body          String
  priority      Int      @default(0)
  data          Json?
  status        String   @default("active") // active, dismissed
  generatedAt   DateTime @default(now())
  expiresAt     DateTime?
  dismissedAt   DateTime?

  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([status])
}

// ─── Experiences (Gamification) ───────────────────────────────────────

model ExperienceTemplate {
  id          String   @id @default(cuid())
  name        String   // "¿Qué dios egipcio eres?"
  slug        String   @unique // egyptian-gods
  theme       String   // egyptian-gods, samurai, italian-regions, pizza-personality, coffee-soul, cocktail-spirit
  category    String   // sushi, cafeteria, bar, vegan, pizza, general
  description String   // tagline
  accentColor String   @default("#F4A623")
  iconEmoji   String   @default("✨")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     ExperienceResult[]
  instances   Experience[]
}

model ExperienceResult {
  id           String   @id @default(cuid())
  templateId   String
  name         String   // "Ra", "Isis", etc
  description  String   // base description
  imageUrl     String?
  traits       String[] // ["líder", "intenso", "fuerte"]
  gender       String   @default("neutral") // "male", "female", "neutral"
  matchCriteria Json?   // { dietTypes: [], ingredients: [], birthMonths: [], hungerLevel: "" }
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  template    ExperienceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissions ExperienceSubmission[]

  @@index([templateId])
}

model Experience {
  id           String   @id @default(cuid())
  restaurantId String
  templateId   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id])
  template     ExperienceTemplate  @relation(fields: [templateId], references: [id])
  submissions  ExperienceSubmission[]

  @@unique([restaurantId]) // 1 experience per restaurant
  @@index([templateId])
}

model ExperienceSubmission {
  id              String    @id @default(cuid())
  experienceId    String
  guestId         String?
  qrUserId        String?
  userName        String
  birthDate       DateTime
  email           String
  assignedResultId String?
  personalizedMsg String?   // Claude-generated text
  teaserMsg       String?   // short teaser shown immediately
  status          String    @default("pending") // pending, processing, sent, failed
  sendAfter       DateTime  // when to send email (now + 10 min)
  submittedAt     DateTime  @default(now())
  resultSentAt    DateTime?

  experience      Experience        @relation(fields: [experienceId], references: [id])
  assignedResult  ExperienceResult? @relation(fields: [assignedResultId], references: [id])

  @@index([experienceId])
  @@index([status])
  @@index([sendAfter])
}

// ─── Analytics: Tickets (POS matching) ────────────────────────────────

model RestaurantTicket {
  id                String           @id @default(uuid())
  restaurantId      String
  restaurant        Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  mesaId            String?
  ticketTotal       Decimal
  ticketCountItems  Int?
  paidAt            DateTime
  matchedSessionId  String?
  matchedSession    Session?         @relation(fields: [matchedSessionId], references: [id])
  matchConfidence   String?          // 'exact' | 'probable' | 'approximate' | 'none'
  uploadedById      String?
  uploadedBy        RestaurantOwner? @relation(fields: [uploadedById], references: [id])
  notes             String?
  createdAt         DateTime         @default(now())

  @@index([restaurantId, paidAt])
  @@index([matchedSessionId])
}

// ─── Analytics: Dish Impressions (batch, lightweight) ─────────────────

model DishImpression {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dishId       String
  restaurantId String
  position     Int?
  visibleMs    Int
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([dishId, createdAt])
  @@index([restaurantId, createdAt])
}

// ─── Dish Favorites ──────────────────────────────────────────────────

model DishFavorite {
  id           String        @id @default(uuid())
  guestId      String?
  guest        GuestProfile? @relation(fields: [guestId], references: [id], onDelete: Cascade)
  qrUserId     String?
  qrUser       QRUser?       @relation(fields: [qrUserId], references: [id], onDelete: Cascade)
  dishId       String
  dish         Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@unique([guestId, dishId], name: "guest_dish_unique")
  @@unique([qrUserId, dishId], name: "user_dish_unique")
  @@index([dishId])
  @@index([restaurantId])
  @@index([restaurantId, createdAt])
  @@index([qrUserId])
  @@index([guestId])
}

// ─── Platform Campaigns (marketing masivo) ─────────────────────────────

model PlatformCampaign {
  id             String   @id @default(cuid())
  subject        String
  status         String   @default("draft") // draft, sending, sent
  totalContacts  Int      @default(0)
  totalSent      Int      @default(0)
  totalErrors    Int      @default(0)
  createdAt      DateTime @default(now())
  sentAt         DateTime?
  contacts       PlatformCampaignContact[]
}

model PlatformCampaignContact {
  id            String    @id @default(cuid())
  campaignId    String
  email         String
  openedAt      DateTime?
  clickedAt     DateTime?
  unsubscribedAt DateTime?
  errorMsg      String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  campaign      PlatformCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, email])
  @@index([email])
  @@index([campaignId])
}
