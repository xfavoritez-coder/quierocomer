{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/diario",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/experience",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cleanup?key=__SEED_SECRET__",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/toteat-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/badge-snapshot",
      "schedule": "*/30 * * * *"
    }
  ]
}
